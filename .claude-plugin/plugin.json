{
  "name": "qa-workflow",
  "version": "0.1.0",
  "description": "End-to-end QA testing workflow plugin: analyze requirements → create test cases → prepare test data → review quality → execute tests → generate reports",
  "author": {
    "name": "QA Workflow Team",
    "email": "qa-workflow@example.com"
  },
  "license": "MIT",
  "keywords": [
    "qa",
    "testing",
    "test-cases",
    "test-data",
    "quality-review",
    "execution",
    "reporting"
  ],
  "plugin": "qa-workflow",
  "commands": [
    {
      "name": "qa-workflow init",
      "description": "Initialize new QA project and configure Jira integration (optional)"
    },
    {
      "name": "qa-workflow analyze",
      "description": "Analyze requirements and identify test scenarios"
    },
    {
      "name": "qa-workflow create-tests",
      "description": "Generate test cases from requirements"
    },
    {
      "name": "qa-workflow modify-tests",
      "description": "Modify and update existing test cases"
    },
    {
      "name": "qa-workflow prepare-data",
      "description": "Create and organize test data"
    },
    {
      "name": "qa-workflow review",
      "description": "Quality review of test cases (QA Lead gate)"
    },
    {
      "name": "qa-workflow execute",
      "description": "Execute tests and track results"
    },
    {
      "name": "qa-workflow report",
      "description": "Generate test execution report"
    }
  ],
  "agents": [
    {
      "name": "qa-engineer",
      "description": "QA Engineer executor persona"
    },
    {
      "name": "qa-lead",
      "description": "QA Lead reviewer persona"
    }
  ],
  "skills": [
    {
      "name": "test-case-generation",
      "description": "Test case creation and validation"
    },
    {
      "name": "test-data-management",
      "description": "Test data organization"
    },
    {
      "name": "coverage-review",
      "description": "Quality and coverage review"
    },
    {
      "name": "execution-reporting",
      "description": "Test execution and report generation"
    }
  ]
}
